  "tokenColors": [
    {
      "name": "Comments",
      "scope": ["comment", "punctuation.definition.comment"],
      "settings": { "foreground": "#6a737d", "fontStyle": "italic" }
    },
    {
      "name": "LaTeX — backslash commands (\\section, \\begin, etc.)",
      "scope": [
        "support.function.tex",
        "support.function.be.latex",
        "keyword.control.tex",
        "keyword.other.tex",
        "entity.name.function.tex",
        "support.class.tex",
        "meta.function.tex"
      ],
      "settings": { "foreground": "#172b4d" }
    },
    {
      "name": "LaTeX — \\begin / \\end keywords",
      "scope": [
        "keyword.control.flow.begin.latex",
        "keyword.control.flow.end.latex",
        "storage.type.function.begin.latex",
        "storage.type.function.end.latex"
      ],
      "settings": { "foreground": "#172b4d", "fontStyle": "bold" }
    },
    {
      "name": "LaTeX — environment names (after \\begin{...})",
      "scope": [
        "variable.parameter.function.latex",
        "support.class.latex",
        "entity.other.attribute-name.latex"
      ],
      "settings": { "foreground": "#22863a" }
    },
    {
      "name": "LaTeX — math mode",
      "scope": [
        "string.other.math.tex",
        "meta.math.block.latex",
        "keyword.operator.math.latex",
        "constant.other.math.tex"
      ],
      "settings": { "foreground": "#0f6b75" }
    },
    {
      "name": "LaTeX — special characters & escapes",
      "scope": [
        "constant.character.escape.tex",
        "constant.character.tex"
      ],
      "settings": { "foreground": "#a01a22" }
    },
    {
      "name": "LaTeX — braces and brackets",
      "scope": [
        "punctuation.definition.arguments.latex",
        "punctuation.definition.group.tex",
        "meta.group.braces.latex"
      ],
      "settings": { "foreground": "#24292e" }
    },
    {
      "name": "LaTeX — section/heading names",
      "scope": ["entity.name.section.latex"],
      "settings": { "foreground": "#172b4d", "fontStyle": "bold" }
    },
    {
      "name": "Strings",
      "scope": ["string", "string.quoted"],
      "settings": { "foreground": "#22863a" }
    },
    {
      "name": "String definition punctuation",
      "scope": [
        "punctuation.definition.string.begin",
        "punctuation.definition.string.end"
      ],
      "settings": { "foreground": "#22863a" }
    },
    {
      "name": "Keywords",
      "scope": ["keyword", "keyword.control"],
      "settings": { "foreground": "#0550ae" }
    },
    {
      "name": "Storage",
      "scope": ["storage", "storage.type", "storage.modifier"],
      "settings": { "foreground": "#0550ae" }
    },
    {
      "name": "Numbers",
      "scope": ["constant.numeric"],
      "settings": { "foreground": "#09885a" }
    },
    {
      "name": "Constants",
      "scope": ["constant.language"],
      "settings": { "foreground": "#0550ae" }
    },
    {
      "name": "Built-in constants",
      "scope": ["constant.other"],
      "settings": { "foreground": "#09885a" }
    },
    {
      "name": "Variables",
      "scope": ["variable"],
      "settings": { "foreground": "#00287a" }
    },
    {
      "name": "Language variables (this, self, etc.)",
      "scope": ["variable.language"],
      "settings": { "foreground": "#0550ae" }
    },
    {
      "name": "Function parameters",
      "scope": ["variable.parameter"],
      "settings": { "foreground": "#00287a", "fontStyle": "italic" }
    },
    {
      "name": "Functions",
      "scope": [
        "entity.name.function",
        "support.function",
        "meta.require",
        "support.function.any-method",
        "variable.function"
      ],
      "settings": { "foreground": "#855818" }
    },
    {
      "name": "Classes and Types",
      "scope": [
        "entity.name.class",
        "entity.name.type",
        "support.class",
        "entity.name.type.class"
      ],
      "settings": { "foreground": "#20677c" }
    },
    {
      "name": "Interfaces",
      "scope": ["entity.name.type.interface"],
      "settings": { "foreground": "#20677c" }
    },
    {
      "name": "Namespaces",
      "scope": ["entity.name.namespace", "entity.name.type.namespace"],
      "settings": { "foreground": "#20677c" }
    },
    {
      "name": "Operators",
      "scope": ["keyword.operator"],
      "settings": { "foreground": "#24292e" }
    },
    {
      "name": "Punctuation",
      "scope": ["punctuation", "punctuation.separator.delimiter"],
      "settings": { "foreground": "#24292e" }
    },
    {
      "name": "HTML/XML tag names",
      "scope": ["entity.name.tag"],
      "settings": { "foreground": "#a01a22" }
    },
    {
      "name": "HTML/XML attribute names",
      "scope": ["entity.other.attribute-name"],
      "settings": { "foreground": "#cf222e", "fontStyle": "italic" }
    },
    {
      "name": "CSS property names",
      "scope": ["support.type.property-name"],
      "settings": { "foreground": "#cf222e" }
    },
    {
      "name": "CSS values",
      "scope": ["support.constant.property-value"],
      "settings": { "foreground": "#0550ae" }
    },
    {
      "name": "JSON property keys",
      "scope": ["support.type.property-name.json"],
      "settings": { "foreground": "#0550ae" }
    },
    {
      "name": "Markdown — headings",
      "scope": ["markup.heading", "entity.name.section.markdown"],
      "settings": { "foreground": "#172b4d", "fontStyle": "bold" }
    },
    {
      "name": "Markdown — bold",
      "scope": ["markup.bold"],
      "settings": { "foreground": "#24292e", "fontStyle": "bold" }
    },
    {
      "name": "Markdown — italic",
      "scope": ["markup.italic"],
      "settings": { "fontStyle": "italic" }
    },
    {
      "name": "Markdown — inline code",
      "scope": ["markup.inline.raw", "markup.inline.raw.string.markdown"],
      "settings": { "foreground": "#a01a22" }
    },
    {
      "name": "Markdown — links",
      "scope": ["markup.underline.link", "string.other.link"],
      "settings": { "foreground": "#0550ae" }
    },
    {
      "name": "Markdown — blockquote",
      "scope": ["markup.quote.markdown"],
      "settings": { "foreground": "#6a737d" }
    },
    {
      "name": "Markdown — list bullets",
      "scope": [
        "beginning.punctuation.definition.list.markdown",
        "punctuation.definition.list.begin.markdown"
      ],
      "settings": { "foreground": "#172b4d" }
    },
    {
      "name": "Regular expressions",
      "scope": ["string.regexp"],
      "settings": { "foreground": "#852042" }
    },
    {
      "name": "Escape characters",
      "scope": ["constant.character.escape"],
      "settings": { "foreground": "#cf222e" }
    },
    {
      "name": "Invalid",
      "scope": ["invalid"],
      "settings": { "foreground": "#cf222e" }
    },
    {
      "name": "Deprecated",
      "scope": ["invalid.deprecated"],
      "settings": { "foreground": "#cf222e", "fontStyle": "italic" }
    },
    {
      "name": "diff — inserted",
      "scope": ["markup.inserted", "markup.inserted.diff"],
      "settings": { "foreground": "#22863a" }
    },
    {
      "name": "diff — deleted",
      "scope": ["markup.deleted", "markup.deleted.diff"],
      "settings": { "foreground": "#cf222e" }
    },
    {
      "name": "diff — changed",
      "scope": ["markup.changed", "markup.changed.diff"],
      "settings": { "foreground": "#b08800" }
    },
    {
      "name": "Python — self/cls",
      "scope": ["variable.parameter.function.language.special.self.python"],
      "settings": { "foreground": "#0550ae", "fontStyle": "italic" }
    },
    {
      "name": "Python — decorators",
      "scope": ["meta.function.decorator.python"],
      "settings": { "foreground": "#855818" }
    },
    {
      "name": "Python — keywords (import/flow)",
      "scope": [
        "keyword.control.import.python",
        "keyword.control.flow.python"
      ],
      "settings": { "foreground": "#0550ae", "fontStyle": "italic" }
    },
    {
      "name": "Python — function parameters",
      "scope": [
        "variable.parameter.function.python",
        "variable.parameter.function.language.python"
      ],
      "settings": { "foreground": "#00287a" }
    },
    {
      "name": "JS/TS — import keyword",
      "scope": [
        "keyword.operator.expression.import",
        "keyword.operator.module"
      ],
      "settings": { "foreground": "#0550ae" }
    },
    {
      "name": "JS/TS — template literals",
      "scope": [
        "string.template",
        "punctuation.definition.template-expression.begin",
        "punctuation.definition.template-expression.end"
      ],
      "settings": { "foreground": "#22863a" }
    },
    {
      "name": "JS/TS — variable constants",
      "scope": ["variable.other.constant"],
      "settings": { "foreground": "#005cc5" }
    },
    {
      "name": "Markup italic",
      "scope": ["markup.italic.markdown"],
      "settings": { "fontStyle": "italic" }
    }
  ],

  "semanticTokenColors": {
    "namespace":           { "foreground": "#20677c" },
    "type":                { "foreground": "#20677c" },
    "class":               { "foreground": "#20677c" },
    "enum":                { "foreground": "#20677c" },
    "interface":           { "foreground": "#20677c" },
    "struct":              { "foreground": "#20677c" },
    "typeParameter":       { "foreground": "#20677c" },
    "parameter":           { "foreground": "#00287a" },
    "variable":            { "foreground": "#00287a" },
    "property":            { "foreground": "#00287a" },
    "enumMember":          { "foreground": "#005cc5" },
    "event":               { "foreground": "#00287a" },
    "function":            { "foreground": "#855818" },
